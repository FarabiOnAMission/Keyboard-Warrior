{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "build debug",
            "command": "C:\\raylib\\w64devkit\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${workspaceFolder}\\game.exe",
                "-I", "C:\\raylib\\raylib\\src",
                "-L", "C:\\raylib\\raylib\\src",
                "-lraylib",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}